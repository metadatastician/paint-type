;;
;; Guix channel definition for paint-type
;;
;; To use this channel, add to ~/.config/guix/channels.scm:
;;
;;   (channel
;;     (name 'paint-type)
;;     (url "https://github.com/JoshuaJewell/paint-type")
;;     (branch "main"))
;;
;; Then: guix pull

(channel
  (version 0)
  (url "https://github.com/JoshuaJewell/paint-type")
  (dependencies
   (channel
     (name 'guix)
     (url "https://git.savannah.gnu.org/git/guix.git")
     (branch "master"))))
