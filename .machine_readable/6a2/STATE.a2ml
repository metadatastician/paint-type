# STATE.a2ml — Project state checkpoint for paint-type

[metadata]
project = "paint-type"
version = "0.2.0-dev"
last-updated = "2026-06-02"
status = "active"  # active | paused | archived

[project-context]
name = "paint-type"
purpose = "Cross-platform open-source image editor. Capable enough for real work, simple enough to reach for without thinking. RGBA16F tile engine with formally-verified ABI bridge, Gossamer shell integration, and Burble collaboration."
completion-percentage = 22
notes = "v0.2.0 closing — in-repo work complete (compositing primitives + UndoGraph + Layer model + brush engine + pt_layer_* FFI all landed; ABI category fully proven; Rust CI green on main since 2026-06-01). Only AffineScript → typed-wasm bridge remains, gated upstream on hyperpolymath/typed-wasm#127 + #130 (paint-type#39)."

[position]
phase = "implementation"   # design | implementation | testing | maintenance | archived
maturity = "experimental"  # experimental | alpha | beta | production | lts
runnable-desktop-mvp = true  # PR #48 (2026-06-02): src/host/ + src/host_core/ + src/ui/

[route-to-mvp]
