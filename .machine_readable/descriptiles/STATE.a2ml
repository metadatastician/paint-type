# STATE.a2ml — Project state checkpoint for paint-type

[metadata]
project = "paint-type"
version = "0.1.0"
last-updated = "2026-05-11"
status = "active"  # active | paused | archived

[project-context]
name = "paint-type"
purpose = "Cross-platform open-source image editor. Capable enough for real work, simple enough to reach for without thinking. RGBA16F tile engine with formally-verified ABI bridge, Gossamer shell integration, and Burble collaboration."
completion-percentage = 10

[position]
phase = "implementation"   # design | implementation | testing | maintenance | archived
maturity = "experimental"  # experimental | alpha | beta | production | lts

[route-to-mvp]
milestones = [
  { name = "v0.1.0: Tile primitive, Idris2 ABI, Zig FFI, Ephapax skeleton", completion = 100 },
  { name = "v0.2.0: Ephapax brush engine, compositing, undo graph, AffineScript bridge", completion = 0 },
  { name = "v0.3.0: Gossamer shell integration, web UI chrome, file I/O", completion = 0 },
  { name = "v0.4.0: Plugin system (WASM sandbox, signing, browser)", completion = 0 },
  { name = "v0.5.0: Collaboration (Burble WebRTC, Groove discovery, LLM channel)", completion = 0 },
  { name = "v1.0.0: Stable release, comprehensive tests, file format spec", completion = 0 },
]

[blockers-and-issues]
# No active blockers — architecture specified, first code landed

[critical-next-actions]
actions = [
  "Implement Ephapax brush engine and tile compositing (v0.2.0)",
  "Generate AffineScript → typed-wasm bridge from Idris2 ABI",
  "Wire idris2 --check into CI for ABI proof validation",
  "Add fuzz harness for pt_tile_blit",
  "Begin Gossamer shell integration planning (v0.3.0)",
]

[maintenance-status]
last-run-utc = "never"
last-report = "docs/reports/maintenance/latest.json"
last-result = "unknown"
open-warnings = 0
open-failures = 0

[ecosystem]
part-of = ["palimpsest", "hyperpolymath estate"]
depends-on = ["gossamer", "burble", "groove", "proven", "stapeln"]
