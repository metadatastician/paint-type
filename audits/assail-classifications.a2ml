    (file "third_party/gossamer/benchmarks/startup-bench.sh")
    (category "CommandInjection")
    (classification "false-positive-cli-flag")
    (audit "audits/audit-track-c-2026-06-23.md")
    (rationale "Vendored third_party/gossamer benchmark. The flagged 'eval' is the gossamer binary's --eval command-line flag with a hardcoded literal argument (window.close()), not the shell eval builtin; there is no injection vector."))
