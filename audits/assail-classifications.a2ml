  ;; ===========================================================================
  ;; Track C (2026-06-23) — paint-type own-code FFI boundary (audited legitimate)
  ;; ===========================================================================

  (classification
    (file "examples/undo_demo.zig")
    (category "UnsafeCode")
    (classification "legitimate-ffi")
    (audit "audits/audit-track-c-2026-06-23.md")
    (rationale "@ptrCast of the address of a stack-allocated [256]u8 buffer to a C nul-terminated string ([*:0]const u8) for a stdlib fopen call; the nul terminator is set explicitly beforehand. No untrusted data."))
  (classification
    (file "src/backends/storage/verisimdb.zig")
    (category "UnsafeCode")
    (classification "legitimate-ffi")
    (audit "audits/audit-track-c-2026-06-23.md")
    (rationale "@constCast(@ptrCast(&dummy)) builds an opaque *anyopaque vtable context pointer to a program-lifetime static; the stub Transport never dereferences ctx, so the const removal is sound."))
  (classification
    (file "src/ephapax/src/lib.rs")
    (category "UnsafeCode")
    (classification "legitimate-ffi")
    (audit "audits/audit-track-c-2026-06-23.md")
    (rationale "Five extern \"C\" calls into the Zig libpt C ABI (pt_tile_alloc/is_initialized/fill/read_pixel/free), each with a // SAFETY: comment; handles are uniquely owned (freed once in Drop), pointer-to-stack-local output params live across the call, and libpt validates null + magic-word internally."))
)
